# Alpha Vantage Proxy Environment Variables
# Copy this to .env on the droplet (for local dev)
# For production, keys are injected via docker-compose volume mount

NODE_ENV=production
PORT=3000

# Tor settings (Tor must be running on the host)
TOR_SOCKS_HOST=127.0.0.1
TOR_SOCKS_PORT=9050
TOR_CONTROL_HOST=127.0.0.1
TOR_CONTROL_PORT=9051
# HashedControlPassword from /etc/tor/torrc
TOR_CONTROL_PASSWORD=16:FE73C2AA84D821D1608FC9309CD462E786F0A49A4AC9D1DBDEE1BFADD0
